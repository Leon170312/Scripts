local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, -12, 1, 0)
StatusLabel.Position = UDim2.new(0, 6, 0, 0)
StatusLabel.BackgroundTransparency = 1
StatusLabel.TextColor3 = Color3.new(1, 1, 1)
StatusLabel.TextScaled = true
StatusLabel.Font = Enum.Font.GothamBold
StatusLabel.Text = "Aimbot READY  |  E=Lock  Tab=Toggle  P=Quit"
StatusLabel.Parent = Frame

local StatusTimer = 0
local lastStatus = ""

Connections.Status = RunService.Heartbeat:Connect(function(dt)
    if not ScriptActive then return end
    StatusTimer = StatusTimer + dt
    if StatusTimer < 0.1 then return end
    StatusTimer = 0

    local status = Holding and "LOCKED" or (_G.AimbotEnabled and "READY" or "OFF")
    local targetName = CurrentTarget and CurrentTarget.Name or "—"
    local newText = string.format("Aimbot: %s  |  Target: %s  |  FOV: %d", status, targetName, FOV_RADIUS)

    if newText ~= lastStatus then
        lastStatus = newText
        StatusLabel.Text = newText
    end

    if Holding then
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 110)
        Stroke.Color = Color3.fromRGB(0, 255, 110)
        Stroke.Transparency = 0.45
    elseif not _G.AimbotEnabled then
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        Stroke.Color = Color3.fromRGB(255, 80, 80)
        Stroke.Transparency = 0.45
    else
        StatusLabel.TextColor3 = Color3.new(1, 1, 1)
        Stroke.Color = Color3.new(1, 1, 1)
        Stroke.Transparency = 0.8
    end
end)

print("[Aimbot] Loaded  |  Mouse API:", moveRel and "OK" or "NOT FOUND — cursor lock disabled")
print("[Aimbot] E=lock  Tab=toggle  P=destroy")
